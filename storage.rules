rules_version = '2';

// Firebase Storage Security Rules for matriXO
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow anyone to upload resumes to the resumes folder
    // This is needed for public job applications
    match /resumes/{fileName} {
      allow read: if request.auth != null;  // Only authenticated users can read
      allow write: if request.auth != null  // Must be authenticated
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType == 'application/pdf';  // Only PDF files
    }
    
    // General application resumes (for when no specific role)
    match /resumes/general/{fileName} {
      allow read: if request.auth != null;  // Only authenticated users can read
      allow write: if request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType == 'application/pdf';  // Only PDF files
    }
    
    // Team photos - public read, admin write
    match /team/{fileName} {
      allow read: if true;  // Anyone can view team photos
      allow write: if request.auth != null;  // Only authenticated users can upload
    }

    // Profile images - public read, only the owning employee can write/delete
    // Path: profile-images/{employeeId}/{fileName}
    match /profile-images/{employeeId}/{fileName} {
      allow read: if true;  // Public read so team page can display photos
      allow write: if request.auth != null  // Must be authenticated
                   && request.resource.size < 3 * 1024 * 1024  // Max 3MB
                   && request.resource.contentType.matches('image/.*');  // Images only
      allow delete: if request.auth != null;  // Authenticated employees can delete
    }

    // Event images - public read, admin write
    match /events/{fileName} {
      allow read: if true;  // Anyone can view event images
      allow write: if request.auth != null;  // Only authenticated users can upload
    }

    // User profile photos - authenticated users can read/write their own photos
    // Path: profile-photos/{userId}
    match /profile-photos/{userId} {
      allow read: if true;  // Public read so profiles can display photos
      allow write: if request.auth != null  // Must be authenticated
                   && request.auth.uid == userId  // Can only write to own folder
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB (images are compressed client-side)
                   && request.resource.contentType.matches('image/.*');  // Images only
      allow delete: if request.auth != null
                   && request.auth.uid == userId;  // Can only delete own photo
    }
    
    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
